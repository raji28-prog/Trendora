# ────────────────────────────────────────────────────────────────
# Trendora Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────────

# Backend API URL
# In development: leave empty — Vite proxy forwards /api → localhost:5000
# In production: set to your Vercel domain (same project = same domain, so also leave empty)
VITE_API_URL=
