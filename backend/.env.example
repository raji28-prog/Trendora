# ────────────────────────────────────────────────────────────────
# Trendora Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ALL values below are required in production unless marked [optional].
# ────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/trendora?retryWrites=true&w=majority"

# JWT Secrets — use long random strings in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Cloudinary [optional] — image uploads skip gracefully if not set
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq AI [optional]
GROQ_API_KEY=gsk_...

# Hugging Face [optional]
HF_TOKEN=hf_...

# Meta / Instagram [optional]
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://your-vercel-domain.vercel.app/api/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=trendora_webhook_verify_token

# CORS — set to your Vercel frontend URL
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Development Mode — set to false in production
DEVELOPMENT_MODE=false
