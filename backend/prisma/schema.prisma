datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  USER
  BUSINESS_OWNER
}

model User {
  id                      String                   @id @default(uuid()) @map("_id")
  uuid                    String                   @unique @default(uuid())
  firstName               String
  lastName                String?
  email                   String                   @unique
  passwordHash            String
  phone                   String?
  profileImage            String?
  role                    Role                     @default(EMPLOYEE)
  status                  String                   @default("ACTIVE")
  emailVerified           Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  
  // Future relationships (Business management)
  businessId              String?

  // Relations
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
  businesses              Business[]
  reviews                 Review[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @map("_id")
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @map("_id")
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @map("_id")
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @map("_id")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Business {
  id           String     @id @default(uuid()) @map("_id")
  name         String
  category     String
  address      String
  phone        String
  website      String?
  images       Json
  status       String     @default("ACTIVE")
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ads          Ad[]
  campaigns    Campaign[]
  leads        Lead[]
  posters      Poster[]
  reviews      Review[]
  posts        Post[]
  teamMembers  TeamMember[]
  subscriptions Subscription[]

  @@map("businesses")
}

model Ad {
  id          String   @id @default(uuid()) @map("_id")
  title       String
  description String?
  imageUrl    String?
  budget      Float
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING")
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}

model Campaign {
  id         String   @id @default(uuid()) @map("_id")
  name       String
  type       String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("DRAFT")
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leads      Lead[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("campaigns")
}

model Lead {
  id         String    @id @default(uuid()) @map("_id")
  firstName  String
  lastName   String?
  email      String
  phone      String?
  status     String    @default("NEW")
  source     String?
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("leads")
}

model Poster {
  id         String   @id @default(uuid()) @map("_id")
  title      String
  imageUrl   String
  format     String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("posters")
}

model Review {
  id            String   @id @default(uuid()) @map("_id")
  rating        Int
  comment       String?
  reviewerName  String
  reviewerEmail String?
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("reviews")
}

model ServiceCategory {
  id          String    @id @default(uuid()) @map("_id")
  name        String
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("service_categories")
}

model Service {
  id          String          @id @default(uuid()) @map("_id")
  name        String
  description String?
  price       Float
  duration    Int             // Duration in minutes
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  packageId   String?
  package     Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("services")
}

model Package {
  id          String    @id @default(uuid()) @map("_id")
  name        String    // e.g. Basic, Pro, Premium
  price       Float     // Price in USD per month
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("packages")
}

model Post {
  id           String   @id @default(uuid()) @map("_id")
  content      String
  platform     String   // e.g. FACEBOOK, INSTAGRAM, TWITTER
  scheduledFor DateTime
  status       String   @default("SCHEDULED") // e.g. SCHEDULED, PUBLISHED, FAILED
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("posts")
}

model TeamMember {
  id         String   @id @default(uuid()) @map("_id")
  name       String
  email      String
  role       String   @default("EDITOR") // e.g. ADMIN, MANAGER, EDITOR
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("team_members")
}

model Subscription {
  id         String   @id @default(uuid()) @map("_id")
  plan       String   @default("FREE") // FREE, PRO, ENTERPRISE
  status     String   @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE
  expiresAt  DateTime
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("subscriptions")
}
